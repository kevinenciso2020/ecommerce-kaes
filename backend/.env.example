# ═══════════════════════════════════════════════════════════════
# KAES ECOMMERCE - Variables de entorno de ejemplo
# Copia este archivo a .env y completa con tus valores reales
# ═══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/kaes_ecommerce"

# ── Frontend/Backend URLs ───────────────────────────────────────
FRONTEND_URL=http://localhost:4321
BACKEND_URL=http://localhost:3001

# ── JWT Secrets ─────────────────────────────────────────────────
JWT_SECRET=tu_jwt_secret_aqui
JWT_REFRESH_SECRET=tu_jwt_refresh_secret_aqui

# ── Cloudinary (archivos e imágenes) ───────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── MercadoPago ─────────────────────────────────────────────────
MP_ACCESS_TOKEN=tu_access_token_mp
MP_WEBHOOK_SECRET=tu_webhook_secret_mp

# ── Wompi ───────────────────────────────────────────────────────
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=tu_public_key_wompi
WOMPI_PRIVATE_KEY=tu_private_key_wompi
WOMPI_WEBHOOK_SECRET=tu_webhook_secret_wompi

# ── Stripe (configurado pero no activo en Colombia) ────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Email (Gmail con App Password) ──────────────────────────────
# Configura en tu cuenta Google:
# 1. Activa verificación en 2 pasos
# 2. Ve a Seguridad > Contraseñas de aplicaciones
# 3. Genera una contraseña para "Correo"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx  # App Password de 16 dígitos
SMTP_FROM_EMAIL=noreply@kaesstore.com