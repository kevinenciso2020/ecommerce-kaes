---

<div class="trinity-container">
  <div class="trinity-wrapper">
    <svg class="trinity-symbol" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="trinityGradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#2c2c2c;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#1a1a1a;stop-opacity:1" />
        </linearGradient>
      </defs>
      <g class="trinity-knot">
        <circle cx="100" cy="55" r="35" fill="none" stroke="url(#trinityGradient)" stroke-width="2.5"/>
        <circle cx="155" cy="127" r="35" fill="none" stroke="url(#trinityGradient)" stroke-width="2.5"/>
        <circle cx="45" cy="127" r="35" fill="none" stroke="url(#trinityGradient)" stroke-width="2.5"/>
        <circle cx="100" cy="55" r="12" fill="url(#trinityGradient)"/>
        <circle cx="155" cy="127" r="12" fill="url(#trinityGradient)"/>
        <circle cx="45" cy="127" r="12" fill="url(#trinityGradient)"/>
        <circle cx="100" cy="100" r="8" fill="url(#trinityGradient)" class="center-dot"/>
      </g>
    </svg>
  </div>
  <div class="trinity-text-container">
    <p class="trinity-text-main">kaes</p>
    <p class="trinity-text-sub">simply eternal</p>
  </div>
</div>

<style>
  .trinity-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  .trinity-wrapper {
    width: 200px;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trinity-symbol {
    width: 100%;
    height: 100%;
  }

  .trinity-knot {
    animation: breathe 4s ease-in-out infinite;
    transform-origin: center;
  }

  .center-dot {
    animation: pulse 2s ease-in-out infinite;
  }

  .trinity-text-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .trinity-text-main {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: lowercase;
    color: var(--color-gray-800);
    margin: 0;
  }

  .trinity-text-sub {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.35em;
    text-transform: lowercase;
    color: var(--color-gray-500);
    margin: 0;
  }

  @keyframes breathe {
    0%, 100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
    50% {
      transform: scale(1.05) rotate(2deg);
      opacity: 0.9;
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trinity-knot,
    .center-dot {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .trinity-wrapper {
      width: 140px;
      height: 140px;
    }
    .trinity-text-main {
      font-size: 2.5rem;
    }
    .trinity-text-sub {
      font-size: 1rem;
    }
  }
</style>
