---
interface Props {
  product: {
    id: string
    name: string
    slug: string
    price: number | string
    category?: { name: string; slug: string }
    images?: { url: string; isMain?: boolean }[]
    isFeatured?: boolean
  }
}

const { product } = Astro.props
const url   = `/productos/${product.slug}`
const img   = product.images?.find(i => i.isMain)?.url || product.images?.[0]?.url
const price = Number(product.price).toLocaleString('es-CO')
---

<a href={url} class="product-card">
  <div class="product-image">
    {img
      ? <img src={img} alt={product.name} loading="lazy" />
      : <div class="product-placeholder">📦</div>
    }
    {product.isFeatured && <span class="badge-featured">Destacado</span>}
  </div>
  <div class="product-info">
    {product.category && <p class="product-category">{product.category.name}</p>}
    <h3 class="product-name">{product.name}</h3>
    <p class="product-price">${price}</p>
  </div>
</a>

<style>
  .product-card {
    display:        flex;
    flex-direction: column;
    border-radius:  var(--radius-lg, 12px);
    overflow:       hidden;
    border:         1.5px solid var(--color-gray-200);
    transition:     all 250ms ease;
    background:     var(--color-white);
    text-decoration: none;
  }

  .product-card:hover {
    transform:    translateY(-4px);
    box-shadow:   0 8px 24px rgba(0,0,0,0.08);
    border-color: transparent;
  }

  .product-image {
    aspect-ratio: 3/4;
    overflow:     hidden;
    background:   var(--color-gray-100);
    position:     relative;
  }

  .product-image img {
    width:      100%;
    height:     100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .product-card:hover .product-image img { transform: scale(1.05); }

  .product-placeholder {
    width:           100%;
    height:          100%;
    display:         flex;
    align-items:     center;
    justify-content: center;
    font-size:       2.5rem;
    color:           var(--color-gray-400);
  }

  .badge-featured {
    position:       absolute;
    top:            0.75rem;
    left:           0.75rem;
    background:     var(--color-black, #0a0a0a);
    color:          var(--color-white, #fff);
    font-size:      0.65rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding:        0.25rem 0.6rem;
    border-radius:  2px;
  }

  .product-info    { padding: 1rem; }

  .product-category {
    font-size:      0.7rem;
    font-weight:    500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color:          var(--color-gray-400);
    margin-bottom:  0.25rem;
  }

  .product-name {
    font-size:     0.95rem;
    font-weight:   500;
    color:         var(--color-gray-800);
    margin-bottom: 0.5rem;
    line-height:   1.3;
  }

  .product-price {
    font-size:   1rem;
    font-weight: 600;
    color:       var(--color-black);
  }
</style>