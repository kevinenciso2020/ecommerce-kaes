---
import ShopLayout from '../../layouts/ShopLayout.astro'
---

<ShopLayout title="Admin - Órdenes">
  <div class="admin-page container" id="admin-content" style="display:none">

    <div class="admin-header">
      <div>
        <h1 class="admin-title">Órdenes</h1>
        <p class="admin-sub">Gestiona los pedidos de los clientes</p>
      </div>
      <div class="filters">
        <select id="filter-status" class="filter-select">
          <option value="">Todos los estados</option>
          <option value="PENDING">Pendiente</option>
          <option value="CONFIRMED">Confirmado</option>
          <option value="PROCESSING">Procesando</option>
          <option value="SHIPPED">Enviado</option>
          <option value="DELIVERED">Entregado</option>
          <option value="CANCELLED">Cancelado</option>
          <option value="REFUNDED">Reembolsado</option>
        </select>
      </div>
    </div>

    <div class="orders-table-wrap">
      <table class="orders-table">
        <thead>
          <tr>
            <th>Orden</th><th>Cliente</th><th>Total</th>
            <th>Estado</th><th>Fecha</th><th>Acciones</th>
          </tr>
        </thead>
        <tbody id="orders-tbody">
          <tr><td colspan="6" class="loading">Cargando...</td></tr>
        </tbody>
      </table>
    </div>

    <div class="pagination" id="pagination"></div>
  </div>

  <div id="no-access" style="display:none" class="no-access">
    <p>No tienes permisos para ver esta página</p>
    <a href="/" class="btn btn-primary">Volver al inicio</a>
  </div>

  <div id="order-modal" class="modal" style="display:none">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Detalle de orden</h2>
        <button class="modal-close" id="close-modal">&times;</button>
      </div>
      <div class="modal-body" id="order-detail"></div>
    </div>
  </div>
</ShopLayout>

<script>
  import { api } from '../../lib/api.js'
  import { currentUser } from '../../stores/auth.store.js'

  var orders = []
  var currentPage = 1
  var totalPages  = 1
  var user = currentUser.get()

  if (!user || user.role !== 'ADMIN') {
    document.getElementById('no-access').style.display = 'flex'
  } else {
    document.getElementById('admin-content').style.display = 'block'
    loadOrders()
    setupEventListeners()
  }

  var statusMap = {
    PENDING:    { label: 'Pendiente',   cls: 'pending'    },
    CONFIRMED:  { label: 'Confirmado',  cls: 'confirmed'  },
    PROCESSING: { label: 'Procesando',  cls: 'processing' },
    SHIPPED:    { label: 'Enviado',     cls: 'shipped'    },
    DELIVERED:  { label: 'Entregado',   cls: 'delivered'  },
    CANCELLED:  { label: 'Cancelado',   cls: 'cancelled'  },
    REFUNDED:   { label: 'Reembolsado', cls: 'refunded'   },
  }

  async function loadOrders(params) {
    try {
      var result = await api.admin.orders(params || {})
      orders      = result.orders
      currentPage = result.page
      totalPages  = result.totalPages
      renderOrders()
      renderPagination()
    } catch (err) {
      document.getElementById('orders-tbody').innerHTML =
        '<tr><td colspan="6" class="error">' + err.message + '</td></tr>'
    }
  }

  function statusOptions(current) {
    return Object.keys(statusMap).map(function(k) {
      return '<option value="' + k + '"' + (current === k ? ' selected' : '') + '>' + statusMap[k].label + '</option>'
    }).join('')
  }

  function renderOrders() {
    var tbody = document.getElementById('orders-tbody')
    if (!orders.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="empty">No hay órdenes</td></tr>'
      return
    }
    tbody.innerHTML = orders.map(function(o) {
      var s = statusMap[o.status] || { label: o.status, cls: '' }
      return '<tr>' +
        '<td><strong>#' + o.id.slice(-6).toUpperCase() + '</strong></td>' +
        '<td><div class="customer-info">' +
          '<span class="customer-name">' + (o.user ? o.user.name : '—') + '</span>' +
          '<span class="customer-email">' + (o.user ? o.user.email : '') + '</span>' +
        '</div></td>' +
        '<td>$' + Number(o.total).toLocaleString('es-CO') + '</td>' +
        '<td><span class="status-badge ' + s.cls + '">' + s.label + '</span></td>' +
        '<td>' + new Date(o.createdAt).toLocaleDateString('es-CO') + '</td>' +
        '<td><div class="action-buttons">' +
          '<button class="btn-icon view-btn" data-id="' + o.id + '" title="Ver">👁️</button>' +
          '<select class="status-select" data-id="' + o.id + '">' + statusOptions(o.status) + '</select>' +
        '</div></td>' +
      '</tr>'
    }).join('')

    document.querySelectorAll('.view-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { viewOrder(btn.getAttribute('data-id')) })
    })
    document.querySelectorAll('.status-select').forEach(function(sel) {
      sel.addEventListener('change', function() { updateStatus(sel.getAttribute('data-id'), sel.value) })
    })
  }

  function renderPagination() {
    var pag = document.getElementById('pagination')
    if (totalPages <= 1) { pag.innerHTML = ''; return }
    var html = ''
    if (currentPage > 1) html += '<button class="page-btn" data-page="' + (currentPage - 1) + '">←</button>'
    html += '<span class="page-info">Página ' + currentPage + ' de ' + totalPages + '</span>'
    if (currentPage < totalPages) html += '<button class="page-btn" data-page="' + (currentPage + 1) + '">→</button>'
    pag.innerHTML = html
    pag.querySelectorAll('.page-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { loadOrders({ page: btn.getAttribute('data-page') }) })
    })
  }

  function setupEventListeners() {
    document.getElementById('filter-status').addEventListener('change', function(e) {
      loadOrders({ status: e.target.value })
    })
    document.getElementById('close-modal').addEventListener('click', closeModal)
    document.getElementById('order-modal').addEventListener('click', function(e) {
      if (e.target === e.currentTarget) closeModal()
    })
  }

  async function updateStatus(orderId, status) {
    try {
      await api.admin.updateOrder(orderId, status)
      loadOrders()
    } catch (err) { alert(err.message) }
  }

  function viewOrder(orderId) {
    var order = orders.find(function(o) { return o.id === orderId })
    if (!order) return
    var itemsHtml = (order.items || []).map(function(item) {
      return '<tr><td>' + (item.product ? item.product.name : 'Producto') + '</td>' +
        '<td>' + item.quantity + '</td>' +
        '<td>$' + Number(item.price).toLocaleString('es-CO') + '</td>' +
        '<td>$' + (item.quantity * Number(item.price)).toLocaleString('es-CO') + '</td></tr>'
    }).join('')

    document.getElementById('order-detail').innerHTML =
      '<div class="order-header">' +
        '<p><strong>Orden #' + order.id.slice(-6).toUpperCase() + '</strong></p>' +
        '<p class="order-date">Fecha: ' + new Date(order.createdAt).toLocaleString('es-CO') + '</p>' +
        (order.notes ? '<p class="order-notes">' + order.notes + '</p>' : '') +
      '</div>' +
      '<div class="order-customer"><h3>Cliente</h3>' +
        '<p>' + (order.user ? order.user.name : '—') + '</p>' +
        '<p>' + (order.user ? order.user.email : '') + '</p>' +
      '</div>' +
      '<div class="order-items"><h3>Productos</h3>' +
        '<table class="items-table"><thead><tr><th>Producto</th><th>Cant.</th><th>Precio</th><th>Total</th></tr></thead>' +
        '<tbody>' + itemsHtml + '</tbody></table>' +
      '</div>' +
      '<div class="order-totals">' +
        '<p><span>Subtotal</span><span>$' + Number(order.subtotal).toLocaleString('es-CO') + '</span></p>' +
        '<p><span>Descuento</span><span>-$' + Number(order.discount).toLocaleString('es-CO') + '</span></p>' +
        '<p><span>Envío</span><span>' + (Number(order.shipping) === 0 ? 'Gratis' : '$' + Number(order.shipping).toLocaleString('es-CO')) + '</span></p>' +
        '<p class="total-row"><span><strong>Total</strong></span><span><strong>$' + Number(order.total).toLocaleString('es-CO') + '</strong></span></p>' +
      '</div>'

    document.getElementById('order-modal').style.display = 'flex'
  }

  function closeModal() {
    document.getElementById('order-modal').style.display = 'none'
  }
</script>

<style>
  .admin-page { padding-top: calc(60px + 2rem); padding-bottom: 4rem; }
  .admin-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
  .admin-title { font-family: var(--font-serif); font-size: 2rem; font-weight: 600; color: var(--color-black); }
  .admin-sub { font-size: 0.875rem; color: var(--color-gray-400); margin-top: 0.25rem; }
  .filter-select { padding: 0.625rem 1rem; border: 1px solid var(--color-gray-200); border-radius: 8px; font-size: 0.875rem; }
  .orders-table-wrap { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 8px; overflow-x: auto; }
  .orders-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .orders-table th { text-align: left; padding: 1rem; background: var(--color-gray-50); font-weight: 600; color: var(--color-gray-500); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .orders-table td { padding: 1rem; border-top: 1px solid var(--color-gray-100); vertical-align: middle; }
  .customer-info { display: flex; flex-direction: column; }
  .customer-name { font-weight: 500; }
  .customer-email { font-size: 0.75rem; color: var(--color-gray-400); }
  .status-badge { display: inline-block; padding: 0.25rem 0.625rem; border-radius: 999px; font-size: 0.75rem; font-weight: 500; }
  .status-badge.pending    { background: #fef3c7; color: #92400e; }
  .status-badge.confirmed  { background: #dbeafe; color: #1e40af; }
  .status-badge.processing { background: #e0e7ff; color: #3730a3; }
  .status-badge.shipped    { background: #d1fae5; color: #065f46; }
  .status-badge.delivered  { background: #dcfce7; color: #166534; }
  .status-badge.cancelled  { background: #fee2e2; color: #991b1b; }
  .status-badge.refunded   { background: #f3e8ff; color: #6b21a8; }
  .action-buttons { display: flex; gap: 0.5rem; align-items: center; }
  .btn-icon { background: none; border: none; cursor: pointer; padding: 0.25rem; font-size: 1rem; }
  .status-select { padding: 0.25rem 0.5rem; border: 1px solid var(--color-gray-200); border-radius: 6px; font-size: 0.75rem; }
  .loading, .error, .empty { text-align: center; padding: 2rem; color: var(--color-gray-400); }
  .error { color: #991b1b; }
  .pagination { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 1.5rem; }
  .page-btn { padding: 0.5rem 1rem; background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 6px; cursor: pointer; }
  .page-info { font-size: 0.875rem; color: var(--color-gray-500); }
  .modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
  .modal-content { background: var(--color-white); border-radius: 12px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
  .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-bottom: 1px solid var(--color-gray-200); }
  .modal-header h2 { font-size: 1.25rem; font-weight: 600; }
  .modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; }
  .modal-body { padding: 1.5rem; }
  .order-header { margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-gray-100); }
  .order-date { color: var(--color-gray-500); font-size: 0.875rem; }
  .order-notes { font-size: 0.8rem; color: var(--color-gray-400); margin-top: 0.25rem; background: var(--color-gray-50); padding: 0.5rem; border-radius: 4px; }
  .order-customer, .order-items { margin-bottom: 1.5rem; }
  .order-customer h3, .order-items h3 { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-gray-400); margin-bottom: 0.75rem; }
  .items-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .items-table th, .items-table td { padding: 0.5rem; text-align: left; border-bottom: 1px solid var(--color-gray-100); }
  .order-totals p { display: flex; justify-content: space-between; padding: 0.375rem 0; font-size: 0.875rem; border-bottom: 1px solid var(--color-gray-50); }
  .order-totals .total-row { font-size: 1rem; padding-top: 0.75rem; border-bottom: none; }
  .no-access { min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; color: var(--color-gray-400); }
</style>