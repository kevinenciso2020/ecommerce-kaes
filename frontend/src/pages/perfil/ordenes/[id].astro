---
import ShopLayout from '../../../layouts/ShopLayout.astro'
---

<ShopLayout title="Detalle de orden">
  <div class="order-page container" id="order-content" style="display:none">

    <a href="/perfil" class="back-link">← Volver a mis órdenes</a>

    <div class="order-header">
      <h1 class="page-title">Orden #<span id="order-id"></span></h1>
      <p class="order-date">Fecha: <span id="order-date"></span></p>
      <span id="order-status" class="status-badge"></span>
    </div>

    <div class="order-grid">
      <div class="order-card">
        <h2 class="card-title">Productos</h2>
        <div id="order-items"></div>
      </div>

      <div class="order-sidebar">
        <div class="order-card">
          <h2 class="card-title">Resumen</h2>
          <div class="totals" id="order-totals"></div>
        </div>

        <div class="order-card">
          <h2 class="card-title">Envío</h2>
          <div id="order-shipping"></div>
        </div>
      </div>
    </div>

  </div>

  <div id="order-loading" class="loading-page">
    <p>Cargando orden...</p>
  </div>

  <div id="order-error" class="error-page" style="display:none">
    <p id="error-message">Error cargando la orden</p>
    <a href="/perfil" class="btn btn-primary">Volver a mis órdenes</a>
  </div>

  <div id="order-unauthorized" class="error-page" style="display:none">
    <p>No tienes permisos para ver esta orden</p>
    <a href="/perfil" class="btn btn-primary">Volver a mis órdenes</a>
  </div>
</ShopLayout>

<script>
  import { api } from '../../../lib/api.js'
  import { currentUser } from '../../../stores/auth.store.js'
  import { escapeHtml } from '../../../lib/sanitize.js'

  const user = currentUser.get()
  const orderId = window.location.pathname.split('/perfil/ordenes/')[1]

  async function loadOrder() {
    if (!user) {
      document.getElementById('order-loading')!.style.display = 'none'
      document.getElementById('order-unauthorized')!.style.display = 'flex'
      return
    }

    try {
      const order = await api.orders.detail(orderId)

      if (order.user?.id !== user.id) {
        document.getElementById('order-loading')!.style.display = 'none'
        document.getElementById('order-unauthorized')!.style.display = 'flex'
        return
      }

      document.getElementById('order-loading')!.style.display = 'none'
      document.getElementById('order-content')!.style.display = 'block'

      document.getElementById('order-id')!.textContent = order.id.slice(-6).toUpperCase()
      document.getElementById('order-date')!.textContent = new Date(order.createdAt).toLocaleString('es-CO')

      const statusEl = document.getElementById('order-status')!
      const statusInfo = statusLabels[order.status]
      statusEl.textContent = statusInfo?.label || order.status
      statusEl.className = `status-badge ${statusInfo?.class || ''}`

      const itemsEl = document.getElementById('order-items')!
      itemsEl.innerHTML = (order.items || []).map((item: any) => `
        <div class="item-row">
          <div class="item-info">
            <span class="item-name">${escapeHtml(item.product?.name || 'Producto')}</span>
            <span class="item-qty">Cantidad: ${item.quantity}</span>
          </div>
          <span class="item-price">$${(item.quantity * Number(item.price)).toLocaleString('es-CO')}</span>
        </div>
      `).join('')

      document.getElementById('order-totals')!.innerHTML = `
        <div class="total-row"><span>Subtotal</span><span>$${Number(order.subtotal || 0).toLocaleString('es-CO')}</span></div>
        <div class="total-row"><span>Descuento</span><span>-$${Number(order.discount || 0).toLocaleString('es-CO')}</span></div>
        <div class="total-row"><span>Envío</span><span>$${Number(order.shipping || 0).toLocaleString('es-CO')}</span></div>
        <div class="total-row total-final"><span>Total</span><span>$${Number(order.total).toLocaleString('es-CO')}</span></div>
      `

      const shippingEl = document.getElementById('order-shipping')!
      if (order.shippingAddress) {
        shippingEl.innerHTML = `
          <p>${escapeHtml(order.shippingAddress.street)}</p>
          <p>${escapeHtml(order.shippingAddress.city)}, ${escapeHtml(order.shippingAddress.state)}</p>
          <p>${escapeHtml(order.shippingAddress.postalCode)}</p>
        `
      } else {
        shippingEl.innerHTML = '<p>Retiro en tienda</p>'
      }

    } catch (err: any) {
      document.getElementById('order-loading')!.style.display = 'none'
      document.getElementById('error-message')!.textContent = err.message || 'Error cargando la orden'
      document.getElementById('order-error')!.style.display = 'flex'
    }
  }

  const statusLabels: Record<string, { label: string; class: string }> = {
    PENDING:    { label: 'Pendiente', class: 'pending' },
    CONFIRMED:  { label: 'Confirmado', class: 'confirmed' },
    PROCESSING: { label: 'Procesando', class: 'processing' },
    SHIPPED:    { label: 'Enviado', class: 'shipped' },
    DELIVERED: { label: 'Entregado', class: 'delivered' },
    CANCELLED: { label: 'Cancelado', class: 'cancelled' },
    REFUNDED:  { label: 'Reembolsado', class: 'refunded' },
  }

  loadOrder()
</script>

<style>
  .order-page {
    padding-top: calc(60px + 2rem);
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-gray-500);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-black);
  }

  .order-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: 0.5rem;
  }

  .order-date {
    font-size: 0.875rem;
    color: var(--color-gray-400);
    margin-bottom: 1rem;
  }

  .status-badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .status-badge.pending { background: #fef3c7; color: #92400e; }
  .status-badge.confirmed { background: #dbeafe; color: #1e40af; }
  .status-badge.processing { background: #e0e7ff; color: #3730a3; }
  .status-badge.shipped { background: #d1fae5; color: #065f46; }
  .status-badge.delivered { background: #dcfce7; color: #166534; }
  .status-badge.cancelled { background: #fee2e2; color: #991b1b; }
  .status-badge.refunded { background: #f3e8ff; color: #6b21a8; }

  .order-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 1.5rem;
    align-items: start;
  }

  .order-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray-400);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .item-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .item-row:last-child {
    border-bottom: none;
  }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .item-name {
    font-weight: 500;
    color: var(--color-black);
  }

  .item-qty {
    font-size: 0.8125rem;
    color: var(--color-gray-400);
  }

  .item-price {
    font-weight: 600;
    color: var(--color-black);
  }

  .totals {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .total-final {
    padding-top: 0.75rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--color-gray-200);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-black);
  }

  #order-shipping p {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    margin: 0.25rem 0;
  }

  .loading-page,
  .error-page {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-gray-400);
  }

  @media (max-width: 768px) {
    .order-grid {
      grid-template-columns: 1fr;
    }

    .order-sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>