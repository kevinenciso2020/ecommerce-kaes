---
import ShopLayout from '../../layouts/ShopLayout.astro'
---

<ShopLayout title="Admin">
  <div class="admin-page container" id="admin-content" style="display:none">

    <div class="admin-header">
      <h1 class="admin-title">Panel de administración</h1>
      <p class="admin-sub">Gestiona tu tienda Kaes</p>
    </div>

    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <p class="stat-label">Usuarios</p>
        <p class="stat-value" id="stat-users">—</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Productos</p>
        <p class="stat-value" id="stat-products">—</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Órdenes</p>
        <p class="stat-value" id="stat-orders">—</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Ingresos</p>
        <p class="stat-value" id="stat-revenue">—</p>
      </div>
    </div>

    <div class="actions-section">
      <h2 class="section-label">Acciones rápidas</h2>
      <div class="actions-grid">
        <a href="/admin/productos" class="action-card">
          <span class="action-icon">👕</span>
          <h3>Productos</h3>
          <p>Crear, editar y eliminar productos</p>
        </a>
        <a href="/admin/ordenes" class="action-card">
          <span class="action-icon">📦</span>
          <h3>Órdenes</h3>
          <p>Ver y gestionar pedidos</p>
        </a>
        <a href="/admin/descuentos" class="action-card">
          <span class="action-icon">🏷️</span>
          <h3>Descuentos</h3>
          <p>Crear descuentos y cupones</p>
        </a>
      </div>
    </div>

  </div>

  <div id="no-access" style="display:none" class="no-access">
    <p>No tienes permisos para ver esta página</p>
    <a href="/" class="btn btn-primary">Volver al inicio</a>
  </div>
</ShopLayout>

<script>
  import { currentUser } from '../../stores/auth.store.js'
  import { api } from '../../lib/api.js'

  const user = currentUser.get()

  if (!user || user.role !== 'ADMIN') {
    document.getElementById('no-access')!.style.display  = 'flex'
  } else {
    document.getElementById('admin-content')!.style.display = 'block'

    api.admin.stats().then(stats => {
      document.getElementById('stat-users')!.textContent    = stats.totalUsers
      document.getElementById('stat-products')!.textContent = stats.totalProducts
      document.getElementById('stat-orders')!.textContent   = stats.totalOrders
      document.getElementById('stat-revenue')!.textContent  =
        '$' + Number(stats.revenue).toLocaleString('es-CO')
    }).catch(() => {})
  }
</script>

<style>
  .admin-page {
    padding-top:    calc(60px + 2rem);
    padding-bottom: 4rem;
  }

  .admin-header {
    margin-bottom:  2rem;
    padding-bottom: 1.5rem;
    border-bottom:  1px solid var(--color-gray-200);
  }

  .admin-title {
    font-family: var(--font-serif);
    font-size:   2rem;
    font-weight: 600;
    color:       var(--color-black);
  }

  .admin-sub {
    font-size:  0.875rem;
    color:      var(--color-gray-400);
    margin-top: 0.25rem;
  }

  .stats-grid {
    display:               grid;
    grid-template-columns: repeat(4, 1fr);
    gap:                   1rem;
    margin-bottom:         3rem;
  }

  .stat-card {
    background:    var(--color-white);
    border:        1px solid var(--color-gray-200);
    border-radius: 8px;
    padding:       1.5rem;
  }

  .stat-label {
    font-size:      0.7rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color:          var(--color-gray-400);
    margin-bottom:  0.5rem;
  }

  .stat-value {
    font-size:   2rem;
    font-weight: 600;
    color:       var(--color-black);
  }

  .section-label {
    font-size:      0.7rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color:          var(--color-gray-400);
    margin-bottom:  1rem;
  }

  .actions-grid {
    display:               grid;
    grid-template-columns: repeat(3, 1fr);
    gap:                   1rem;
  }

  .action-card {
    display:        flex;
    flex-direction: column;
    gap:            0.5rem;
    padding:        1.5rem;
    background:     var(--color-white);
    border:         1px solid var(--color-gray-200);
    border-radius:  8px;
    transition:     all 200ms;
  }

  .action-card:hover {
    border-color: var(--color-black);
    transform:    translateY(-2px);
    box-shadow:   var(--shadow-md);
  }

  .action-icon { font-size: 1.8rem; }

  .action-card h3 {
    font-size:   0.95rem;
    font-weight: 600;
    color:       var(--color-black);
  }

  .action-card p {
    font-size: 0.8rem;
    color:     var(--color-gray-400);
  }

  .no-access {
    min-height:      70vh;
    display:         flex;
    flex-direction:  column;
    align-items:     center;
    justify-content: center;
    gap:             1rem;
    color:           var(--color-gray-400);
    text-align:      center;
  }

  @media (max-width: 768px) {
    .stats-grid   { grid-template-columns: repeat(2, 1fr); }
    .actions-grid { grid-template-columns: 1fr; }
  }
</style>