---
import ShopLayout from '../../layouts/ShopLayout.astro'
import CelticKnotAnimation from '../../components/admin/CelticKnotAnimation'
import '../../styles/admin.css'
---

<ShopLayout title="Estudio">
  <div class="admin-page" id="studio-content" style="display:none">

    <div class="admin-header">
      <h1 class="admin-title">Estudio</h1>
      <p class="admin-sub">Gestiona tus activos multimedia</p>
    </div>

    <div class="studio-grid">
      <div class="studio-main">
        <div class="studio-card">
          <div class="studio-card-header">
            <h2>Biblioteca de Medios</h2>
            <button class="btn-upload" id="upload-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Subir archivos
            </button>
          </div>

          <div class="media-filters">
            <button class="filter-btn active" data-filter="all">Todos</button>
            <button class="filter-btn" data-filter="image">Imagenes</button>
            <button class="filter-btn" data-filter="video">Videos</button>
          </div>

          <div class="media-grid" id="media-grid">
            <div class="loading">Cargando medios...</div>
          </div>
        </div>

        <div class="studio-card">
          <div class="studio-card-header">
            <h2>Productos sin Imagen</h2>
            <span class="badge" id="orphan-count">0</span>
          </div>
          <div class="orphan-products" id="orphan-products">
            <div class="loading">Cargando...</div>
          </div>
        </div>
      </div>

      <div class="studio-sidebar">
        <div class="studio-card knot-card">
          <div class="studio-card-header">
            <h2>Animacion Decorativa</h2>
          </div>
          <div class="knot-container">
            <CelticKnotAnimation client:visible size={200} />
          </div>
          <p class="knot-hint">Esta animacion se carga solo cuando es visible</p>
        </div>

        <div class="studio-card">
          <div class="studio-card-header">
            <h2>Estadisticas</h2>
          </div>
          <div class="stats-list">
            <div class="stat-item">
              <span class="stat-label">Total de archivos</span>
              <span class="stat-num" id="stat-total">0</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Imagenes</span>
              <span class="stat-num" id="stat-images">0</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Videos</span>
              <span class="stat-num" id="stat-videos">0</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Almacenamiento</span>
              <span class="stat-num" id="stat-storage">0 MB</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <input type="file" id="file-input" multiple accept="image/*,video/*" style="display:none">
  </div>

  <div id="no-access" style="display:none" class="no-access">
    <p>No tienes permisos para ver esta pagina</p>
    <a href="/" class="btn btn-primary">Volver al inicio</a>
  </div>
</ShopLayout>

<script>
  import { currentUser } from '../../stores/auth.store.js'
  import { api } from '../../lib/api.js'

  const initAuth = () => {
    const savedUser = localStorage.getItem('user')
    const savedToken = localStorage.getItem('accessToken')
    if (savedUser && savedToken) {
      try {
        const user = JSON.parse(savedUser)
        currentUser.set(user)
        return user
      } catch {
        return null
      }
    }
    return null
  }

  const user = initAuth()

  if (!user || user.role !== 'ADMIN') {
    if (user) {
      document.getElementById('no-access').style.display = 'flex'
    }
  } else {
    document.getElementById('studio-content').style.display = 'block'
    initStudio()
  }

  async function initStudio() {
    loadProducts()
    setupEventListeners()
  }

  async function loadProducts() {
    try {
      const products = await api.admin.products({ limit: 100 })
      const orphanList = document.getElementById('orphan-products')
      const orphanCount = document.getElementById('orphan-count')

      const orphans = products.products.filter(p => !p.images || p.images.length === 0)

      if (orphanCount) orphanCount.textContent = orphans.length.toString()

      if (orphans.length === 0) {
        if (orphanList) orphanList.innerHTML = '<div class="empty">Todos los productos tienen imagen</div>'
      } else {
        if (orphanList) orphanList.innerHTML = orphans.map(p => `
          <div class="orphan-item">
            <div class="orphan-info">
              <span class="orphan-name">${p.name}</span>
              <span class="orphan-slug">${p.slug}</span>
            </div>
            <a href="/admin/productos?edit=${p.id}" class="btn-add-image">Agregar imagen</a>
          </div>
        `).join('')
      }

      document.getElementById('stat-total').textContent = products.products.length.toString()
      document.getElementById('stat-images').textContent = products.products.reduce((acc, p) => acc + (p.images?.length || 0), 0).toString()

    } catch (err) {
      console.error('Error loading products:', err)
    }
  }

  function setupEventListeners() {
    const uploadBtn = document.getElementById('upload-btn')
    const fileInput = document.getElementById('file-input')

    uploadBtn?.addEventListener('click', () => fileInput?.click())

    fileInput?.addEventListener('change', async (e) => {
      const files = (e.target as HTMLInputElement).files
      if (files && files.length > 0) {
        await uploadFiles(files)
      }
    })

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'))
        ;(e.target as HTMLElement).classList.add('active')
      })
    })
  }

  async function uploadFiles(files: FileList) {
    const formData = new FormData()
    for (let i = 0; i < files.length; i++) {
      formData.append('images', files[i])
    }

    try {
      const response = await fetch('/api/v1/admin/products', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${localStorage.getItem('accessToken')}`
        },
        body: formData
      })

      if (response.ok) {
        alert('Archivos subidos correctamente')
        loadProducts()
      }
    } catch (err) {
      console.error('Upload error:', err)
      alert('Error al subir archivos')
    }
  }
</script>

<style>
  .studio-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
  }

  .studio-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .studio-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .studio-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .studio-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .studio-card-header h2 {
    font-size: 1rem;
    font-weight: 600;
  }

  .btn-upload {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-black);
    color: var(--color-white);
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 200ms;
  }

  .btn-upload:hover {
    background: var(--color-gray-600);
  }

  .media-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .filter-btn {
    padding: 0.375rem 0.75rem;
    background: none;
    border: 1px solid var(--color-gray-200);
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 200ms;
  }

  .filter-btn.active, .filter-btn:hover {
    background: var(--color-black);
    color: var(--color-white);
    border-color: var(--color-black);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.75rem;
    min-height: 200px;
  }

  .media-item {
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-gray-100);
    position: relative;
    cursor: pointer;
  }

  .media-item img, .media-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-item:hover .media-overlay {
    opacity: 1;
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 200ms;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .media-overlay button {
    background: var(--color-white);
    border: none;
    border-radius: 4px;
    padding: 0.25rem;
    cursor: pointer;
  }

  .badge {
    background: var(--color-gray-100);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .knot-card {
    text-align: center;
  }

  .knot-container {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .knot-hint {
    font-size: 0.7rem;
    color: var(--color-gray-400);
  }

  .stats-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .stat-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .stat-item .stat-label {
    font-size: 0.8rem;
    color: var(--color-gray-500);
  }

  .stat-item .stat-num {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .orphan-products {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 300px;
    overflow-y: auto;
  }

  .orphan-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: var(--color-gray-50);
    border-radius: 8px;
  }

  .orphan-info {
    display: flex;
    flex-direction: column;
  }

  .orphan-name {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .orphan-slug {
    font-size: 0.7rem;
    color: var(--color-gray-400);
  }

  .btn-add-image {
    font-size: 0.75rem;
    color: var(--color-black);
    text-decoration: underline;
    cursor: pointer;
  }

  .loading, .empty {
    text-align: center;
    padding: 2rem;
    color: var(--color-gray-400);
    font-size: 0.875rem;
  }

  @media (max-width: 1024px) {
    .studio-grid {
      grid-template-columns: 1fr;
    }

    .studio-sidebar {
      order: -1;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .studio-sidebar .studio-card {
      flex: 1;
      min-width: 280px;
    }
  }
</style>
