---
import ShopLayout from '../../layouts/ShopLayout.astro'

let products: any[]   = []
let categories: any[] = []
let pagination: any   = {}

const { searchParams } = Astro.url
const page     = searchParams.get('page')     || '1'
const category = searchParams.get('category') || ''
const search   = searchParams.get('search')   || ''
const minPrice = searchParams.get('minPrice') || ''
const maxPrice = searchParams.get('maxPrice') || ''
const size     = searchParams.get('size')     || ''

const queryParams: Record<string, string> = { page, limit: '12' }
if (category) queryParams.category = category
if (search)   queryParams.search   = search
if (minPrice) queryParams.minPrice = minPrice
if (maxPrice) queryParams.maxPrice = maxPrice
if (size)     queryParams.size     = size

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api/v1'

try {
  const [productsRes, categoriesRes] = await Promise.all([
    fetch(`${apiUrl}/products?${new URLSearchParams(queryParams)}`),
    fetch(`${apiUrl}/products/categories`)
  ])
  if (productsRes.ok) {
    const data = await productsRes.json()
    products   = Array.isArray(data.products) ? data.products : []
    pagination = data.pagination || {}
  }
  if (categoriesRes.ok) {
    const data = await categoriesRes.json()
    categories = Array.isArray(data) ? data : []
  }
} catch (e) {
  console.error('Error:', e)
}

const hasFilters = !!(category || search || minPrice || maxPrice || size)
---

<ShopLayout title="Productos">
  <div class="catalog-page">

    <aside class="sidebar">
      <h3 class="sidebar-title">Filtros</h3>

      <div class="filter-group">
        <label class="filter-label">Buscar</label>
        <input type="text" id="search-input" class="form-input" placeholder="Buscar..." value={search} />
      </div>

      <div class="filter-group">
        <label class="filter-label">Categoría</label>
        <div class="filter-options">
          <a href="/productos" class={!category ? 'filter-option active' : 'filter-option'}>
            Todas
          </a>
          {categories.map(cat => {
            const isActive = category === cat.slug
            const url = `/productos?category=${cat.slug}`
            return (
              <a href={url} class={isActive ? 'filter-option active' : 'filter-option'}>
                {cat.name}
              </a>
            )
          })}
        </div>
      </div>

      <div class="filter-group">
        <label class="filter-label">Talla</label>
        <div class="size-options">
          {['XS','S','M','L','XL','XXL'].map(s => {
            const isActive = size === s
            const url = `/productos?size=${s}`
            return (
              <a href={url} class={isActive ? 'size-btn active' : 'size-btn'}>
                {s}
              </a>
            )
          })}
        </div>
      </div>

      <div class="filter-group">
        <label class="filter-label">Precio</label>
        <div class="price-inputs">
          <input type="number" id="min-price" class="form-input" placeholder="Mín" value={minPrice} />
          <span>—</span>
          <input type="number" id="max-price" class="form-input" placeholder="Máx" value={maxPrice} />
        </div>
        <button class="btn btn-outline btn-sm" id="apply-price">Aplicar</button>
      </div>

      {hasFilters && (
        <a href="/productos" class="clear-btn">Limpiar filtros</a>
      )}
    </aside>

    <main class="catalog-main">
      <div class="catalog-header">
        <h1 class="catalog-title">
          {category
            ? (categories.find(c => c.slug === category)?.name || 'Productos')
            : 'Colección'
          }
        </h1>
        <span class="catalog-count">{pagination.total || products.length} productos</span>
      </div>

      {products.length === 0 ? (
        <div class="empty-state">
          <p>No se encontraron productos</p>
          <a href="/productos" class="btn btn-outline">Ver todos</a>
        </div>
      ) : (
        <div class="products-grid">
          {products.map(product => {
            const productUrl = `/productos/${product.slug}`
            const imageUrl   = product.images?.[0]?.url
            const price      = Number(product.price).toLocaleString('es-CO')
            const sizes      = [...new Set((product.variants || []).map((v: any) => v.size).filter(Boolean))].slice(0, 3)
            return (
              <a href={productUrl} class="product-card">
                <div class="product-image">
                  {imageUrl
                    ? <img src={imageUrl} alt={product.name} loading="lazy" />
                    : <div class="product-image-placeholder">📦</div>
                  }
                  {product.isFeatured && <span class="product-badge">Destacado</span>}
                </div>
                <div class="product-info">
                  <p class="product-category">{product.category?.name}</p>
                  <h3 class="product-name">{product.name}</h3>
                  <div class="product-footer">
                    <p class="product-price">${price}</p>
                    <div class="product-sizes">
                      {sizes.map((s: any) => <span class="size-tag">{s}</span>)}
                    </div>
                  </div>
                </div>
              </a>
            )
          })}
        </div>
      )}

      {pagination.totalPages > 1 && (
        <div class="pagination">
          {pagination.page > 1 && (
            <a href={`/productos?page=${pagination.page - 1}`} class="btn btn-outline">← Anterior</a>
          )}
          <span class="pagination-info">Página {pagination.page} de {pagination.totalPages}</span>
          {pagination.page < pagination.totalPages && (
            <a href={`/productos?page=${pagination.page + 1}`} class="btn btn-outline">Siguiente →</a>
          )}
        </div>
      )}
    </main>

  </div>
</ShopLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  let timeout: ReturnType<typeof setTimeout>

  searchInput?.addEventListener('input', () => {
    clearTimeout(timeout)
    timeout = setTimeout(() => {
      const p = new URLSearchParams(window.location.search)
      if (searchInput.value) p.set('search', searchInput.value)
      else p.delete('search')
      p.delete('page')
      window.location.href = `/productos?${p}`
    }, 500)
  })

  document.getElementById('apply-price')?.addEventListener('click', () => {
    const min = (document.getElementById('min-price') as HTMLInputElement).value
    const max = (document.getElementById('max-price') as HTMLInputElement).value
    const p   = new URLSearchParams(window.location.search)
min ? p.set('minPrice', min) : p.delete('minPrice')
max ? p.set('maxPrice', max) : p.delete('maxPrice')

p.delete('page')
    window.location.href = `/productos?${p}`
  })
</script>

<style>
  .catalog-page {
    display:   flex;
    gap:       2rem;
    max-width: 1280px;
    margin:    0 auto;
    padding:   calc(60px + 2rem) 2rem 4rem;
  }

  .sidebar       { width: 220px; flex-shrink: 0; }
  .sidebar-title {
    font-size:      0.7rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color:          var(--color-gray-400);
    margin-bottom:  1.5rem;
  }

  .filter-group  { margin-bottom: 1.5rem; }
  .filter-label  {
    display:        block;
    font-size:      0.7rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color:          var(--color-gray-400);
    margin-bottom:  0.6rem;
  }

  .filter-options { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-option  {
    padding:       0.35rem 0.6rem;
    border-radius: 4px;
    font-size:     0.85rem;
    color:         var(--color-gray-600);
    transition:    all 150ms;
  }
  .filter-option:hover,
  .filter-option.active { background: var(--color-gray-100); color: var(--color-black); font-weight: 500; }

  .size-options  { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .size-btn {
    padding:       0.2rem 0.55rem;
    border:        1px solid var(--color-gray-200);
    border-radius: 2px;
    font-size:     0.75rem;
    font-weight:   500;
    color:         var(--color-gray-600);
    transition:    all 150ms;
  }
  .size-btn:hover,
  .size-btn.active { border-color: var(--color-black); background: var(--color-black); color: white; }

  .price-inputs  { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.6rem; }
  .price-inputs .form-input { flex: 1; padding: 0.35rem 0.5rem; font-size: 0.8rem; }
  .btn-sm        { padding: 0.35rem 0.9rem; font-size: 0.78rem; }
  .clear-btn     { display: block; font-size: 0.8rem; color: var(--color-danger); margin-top: 0.5rem; }

  .catalog-main  { flex: 1; min-width: 0; }
  .catalog-header {
    display:         flex;
    align-items:     baseline;
    justify-content: space-between;
    margin-bottom:   1.5rem;
  }
  .catalog-title {
    font-family: var(--font-serif);
    font-size:   1.6rem;
    font-weight: 600;
    color:       var(--color-black);
  }
  .catalog-count { font-size: 0.8rem; color: var(--color-gray-400); }

  .empty-state {
    display:         flex;
    flex-direction:  column;
    align-items:     center;
    gap:             1rem;
    padding:         4rem;
    text-align:      center;
    color:           var(--color-gray-400);
  }

  .product-card {
    display:        flex;
    flex-direction: column;
    border-radius:  6px;
    overflow:       hidden;
    border:         1px solid var(--color-gray-200);
    transition:     all 200ms;
    background:     var(--color-white);
  }
  .product-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: transparent; }

  .product-image {
    position:     relative;
    aspect-ratio: 3/4;
    overflow:     hidden;
    background:   var(--color-gray-100);
  }
  .product-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms; }
  .product-card:hover .product-image img { transform: scale(1.04); }
  .product-image-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }

  .product-badge {
    position:       absolute;
    top:            0.6rem;
    left:           0.6rem;
    background:     var(--color-black);
    color:          white;
    font-size:      0.6rem;
    font-weight:    600;
    padding:        2px 7px;
    border-radius:  2px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .product-info     { padding: 0.9rem; }
  .product-category {
    font-size:      0.65rem;
    font-weight:    600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color:          var(--color-gray-400);
    margin-bottom:  0.2rem;
  }
  .product-name   { font-size: 0.875rem; font-weight: 500; color: var(--color-gray-800); margin-bottom: 0.6rem; line-height: 1.3; }
  .product-footer { display: flex; align-items: center; justify-content: space-between; }
  .product-price  { font-size: 0.95rem; font-weight: 600; color: var(--color-black); }
  .product-sizes  { display: flex; gap: 0.2rem; }
  .size-tag       { font-size: 0.6rem; padding: 1px 4px; border: 1px solid var(--color-gray-200); border-radius: 2px; color: var(--color-gray-400); }

  .pagination      { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 3rem; }
  .pagination-info { font-size: 0.875rem; color: var(--color-gray-400); }

  @media (max-width: 768px) {
    .catalog-page { flex-direction: column; padding: calc(60px + 1rem) 1rem 3rem; }
    .sidebar      { width: 100%; }
  }
</style>