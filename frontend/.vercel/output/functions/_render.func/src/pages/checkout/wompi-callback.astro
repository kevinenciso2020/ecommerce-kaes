---
import ShopLayout from '../../layouts/ShopLayout.astro'
import '../../styles/checkout-result.css'
---

<ShopLayout title="Procesando pago">
  <div class="payment-result-page container">
    <div class="result-card">
      <div class="result-icon">⏳</div>
      <h1 class="result-title">Procesando pago...</h1>
      <p class="result-message">Por favor espera mientras verificamos tu pago.</p>
      <div id="payment-result" class="payment-result"></div>
    </div>
  </div>
</ShopLayout>

<script>
  import { api } from '../../lib/api.js'

  const params = new URLSearchParams(window.location.search)
  const orderId = params.get('orderId')

  const resultEl = document.getElementById('payment-result')

  async function checkPayment() {
    if (!orderId) {
      window.location.href = '/perfil/ordenes'
      return
    }

    try {
      const order = await api.payments.getStatus(orderId)

      if (order.status === 'CONFIRMED') {
        window.location.href = `/checkout/success?external_reference=${orderId}`
      } else if (order.status === 'CANCELLED') {
        window.location.href = `/checkout/failure?orderId=${orderId}`
      } else {
        setTimeout(checkPayment, 2000)
      }
    } catch (err) {
      console.error('Error verificando pago:', err)
      setTimeout(checkPayment, 2000)
    }
  }

  checkPayment()
</script>

<style>
  .payment-result-page {
    padding-top: calc(var(--header-height) + var(--space-8));
    padding-bottom: var(--space-16);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .result-card {
    background: var(--color-white);
    border: 1.5px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-12);
    text-align: center;
    max-width: 480px;
    width: 100%;
  }

  .result-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-gray-200);
    color: var(--color-gray-600);
    font-size: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
  }

  .result-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .result-message {
    color: var(--color-gray-600);
    margin-bottom: var(--space-6);
  }
</style>