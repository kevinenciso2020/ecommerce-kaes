---
import ShopLayout from '../../layouts/ShopLayout.astro'
import '../../styles/checkout-result.css'
---

<ShopLayout title="Pago pendiente">
  <div class="payment-result-page container">
    <div class="result-card pending">
      <div class="result-icon">⏳</div>
      <h1 class="result-title">Pago en proceso</h1>
      <p class="result-message">Tu pago está siendo procesado. Te notificaremos cuando sea confirmado.</p>
      <a href="/perfil/ordenes" class="btn btn-primary">Ver mis pedidos</a>
    </div>
  </div>
</ShopLayout>

<style>
  .payment-result-page {
    padding-top: calc(var(--header-height) + var(--space-8));
    padding-bottom: var(--space-16);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .result-card {
    background: var(--color-white);
    border: 1.5px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-12);
    text-align: center;
    max-width: 480px;
    width: 100%;
  }

  .result-card.pending {
    border-color: #f59e0b;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  }

  .result-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #f59e0b;
    color: white;
    font-size: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
  }

  .result-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .result-message {
    color: var(--color-gray-600);
    margin-bottom: var(--space-6);
  }
</style>