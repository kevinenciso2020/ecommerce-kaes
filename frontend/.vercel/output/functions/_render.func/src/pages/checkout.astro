---
import ShopLayout from '../layouts/ShopLayout.astro'
import '../styles/checkout.css'
---

<ShopLayout title="Checkout">
  <div class="checkout-page container">

    <h1 class="page-title">Finalizar compra</h1>

    <div id="checkout-empty" style="display:none" class="checkout-empty">
      <p>No tienes productos en el carrito</p>
      <a href="/productos" class="btn btn-primary">Ver productos</a>
    </div>

    <div id="checkout-content" style="display:none" class="checkout-layout">

      <!-- Formulario -->
      <div class="checkout-form">

        <div class="form-section">
          <h2 class="section-title">Información de contacto</h2>
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Nombre completo</label>
              <input type="text" id="full-name" class="form-input" placeholder="Tu nombre" />
            </div>
            <div class="form-group">
              <label class="form-label">Teléfono</label>
              <input type="tel" id="phone" class="form-input" placeholder="300 000 0000" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2 class="section-title">Dirección de envío</h2>
          <div class="form-group">
            <label class="form-label">Dirección</label>
            <input type="text" id="street" class="form-input" placeholder="Calle, número, apto" />
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Ciudad</label>
              <input type="text" id="city" class="form-input" placeholder="Ciudad" />
            </div>
            <div class="form-group">
              <label class="form-label">Departamento</label>
              <input type="text" id="department" class="form-input" placeholder="Departamento" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2 class="section-title">Método de pago</h2>
          <div class="payment-methods">
            <label class="payment-option">
              <input type="radio" name="payment" value="wompi" checked />
              <div class="payment-card">
                <span class="payment-icon">💳</span>
                <div>
                  <p class="payment-name">Wompi</p>
                  <p class="payment-desc">Tarjetas, Nequi, PSE, Daviplata</p>
                </div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="payment" value="mercadopago" />
              <div class="payment-card">
                <span class="payment-icon">🏦</span>
                <div>
                  <p class="payment-name">MercadoPago</p>
                  <p class="payment-desc">PSE, Nequi, efectivo y más</p>
                </div>
              </div>
            </label>
          </div>
        </div>

        <div id="checkout-error" class="checkout-error" style="display:none"></div>

        <button class="btn btn-primary btn-full" id="place-order-btn">
          Confirmar pedido
        </button>

      </div>

      <!-- Resumen -->
      <div class="order-summary">
        <h2 class="summary-title">Tu pedido</h2>
        <div id="order-items"></div>
        <div class="summary-divider"></div>

        <!-- Aplicar cupón -->
        <div class="coupon-section">
          <div class="coupon-input-group">
            <input type="text" id="coupon-code" class="coupon-input" placeholder="Código de cupón" />
            <button type="button" id="apply-coupon-btn" class="coupon-btn">Aplicar</button>
          </div>
          <div id="coupon-message" class="coupon-message"></div>
          <div id="coupon-applied" class="coupon-applied" style="display:none">
            <span id="applied-code"></span>
            <button type="button" id="remove-coupon-btn" class="remove-coupon-btn">✕</button>
          </div>
        </div>

        <div class="summary-divider"></div>
        <div class="summary-row">
          <span>Subtotal</span>
          <span id="order-subtotal">$0</span>
        </div>
        <div class="summary-row" id="discount-row" style="display:none">
          <span>Descuento</span>
          <span id="order-discount" class="discount-amount">-$0</span>
        </div>
        <div class="summary-row">
          <span>Envío</span>
          <span class="shipping-free">Gratis</span>
        </div>
        <div class="summary-divider"></div>
        <div class="summary-row total-row">
          <span>Total</span>
          <span id="order-total">$0</span>
        </div>
      </div>

    </div>
  </div>
</ShopLayout>

<script>
  import { cartItems, cartTotal, clearCart } from '../stores/cart.store.js'
  import { applyCoupon, removeCoupon, getCouponCode } from '../stores/coupon.store.js'
  import { api } from '../lib/api.js'
  import { sanitizeCartItem } from '../lib/sanitize.js'

  let currentDiscount = 0
  let appliedCouponData = null

  // Mostrar cupón guardado si existe
  const savedCoupon = getCouponCode()
  if (savedCoupon) {
    const codeEl = document.getElementById('applied-code')
    const appliedEl = document.getElementById('coupon-applied')
    const inputEl = document.getElementById('coupon-code')
    if (codeEl) codeEl.textContent = savedCoupon
    if (appliedEl) appliedEl.style.display = 'flex'
    if (inputEl) inputEl.style.display = 'none'
  }

  // Función para actualizar totales
  const updateTotals = (subtotal, discount = 0) => {
    currentDiscount = discount
    const discountRow = document.getElementById('discount-row')
    const discountEl = document.getElementById('order-discount')
    const totalEl = document.getElementById('order-total')

    if (discount > 0 && discountRow && discountEl && totalEl) {
      discountRow.style.display = 'flex'
      discountEl.textContent = '-$' + Number(discount).toLocaleString('es-CO')
      const total = subtotal - discount
      totalEl.textContent = '$' + Number(Math.max(0, total)).toLocaleString('es-CO')
    } else if (totalEl) {
      discountRow.style.display = 'none'
      totalEl.textContent = '$' + Number(subtotal).toLocaleString('es-CO')
    }
  }

  // Aplicar cupón
  document.getElementById('apply-coupon-btn')?.addEventListener('click', async () => {
    const codeInput = document.getElementById('coupon-code') as HTMLInputElement | null
    const messageEl = document.getElementById('coupon-message')
    const appliedEl = document.getElementById('coupon-applied')

    const code = codeInput?.value.trim().toUpperCase()
    if (!code) {
      if (messageEl) {
        messageEl.textContent = 'Ingresa un código'
        messageEl.className = 'coupon-message error'
      }
      return
    }

    try {
      const result = await api.coupons.validate(code)

      if (result.valid) {
        appliedCouponData = result.coupon
        applyCoupon(code, result.coupon)

        const codeEl = document.getElementById('applied-code')
        if (codeEl) codeEl.textContent = code
        if (appliedEl) appliedEl.style.display = 'flex'
        if (codeInput) codeInput.style.display = 'none'
        if (messageEl) {
          messageEl.textContent = result.coupon.type === 'PERCENTAGE'
            ? `${result.coupon.value}% de descuento aplicado`
            : `$${Number(result.coupon.value).toLocaleString('es-CO')} de descuento aplicado`
          messageEl.className = 'coupon-message success'
        }

        const subtotal = cartTotal.get()
        const discount = result.coupon.type === 'PERCENTAGE'
          ? subtotal * (parseFloat(result.coupon.value) / 100)
          : parseFloat(result.coupon.value)
        updateTotals(subtotal, discount)
      } else {
        if (messageEl) {
          messageEl.textContent = result.message || 'Cupón inválido'
          messageEl.className = 'coupon-message error'
        }
      }
    } catch (err) {
      if (messageEl) {
        messageEl.textContent = err.message || 'Error al validar cupón'
        messageEl.className = 'coupon-message error'
      }
    }
  })

  // Remover cupón
  document.getElementById('remove-coupon-btn')?.addEventListener('click', () => {
    removeCoupon()
    appliedCouponData = null

    const codeInput = document.getElementById('coupon-code') as HTMLInputElement | null
    const appliedEl = document.getElementById('coupon-applied')
    const messageEl = document.getElementById('coupon-message')
    const discountRow = document.getElementById('discount-row')

    if (codeInput) {
      codeInput.style.display = 'block'
      codeInput.value = ''
    }
    if (appliedEl) appliedEl.style.display = 'none'
    if (messageEl) {
      messageEl.textContent = ''
      messageEl.className = 'coupon-message'
    }

    const subtotal = cartTotal.get()
    updateTotals(subtotal, 0)
  })

  const items = cartItems.get().map(sanitizeCartItem)
  const subtotal = cartTotal.get()

  // Verificar si hay items
  if (items.length === 0) {
    document.getElementById('checkout-empty').style.display = 'flex'
  } else {
    document.getElementById('checkout-content').style.display = 'grid'

    const orderItemsEl = document.getElementById('order-items')
    if (orderItemsEl) {
      orderItemsEl.innerHTML = items.map(item => `
        <div class="order-item">
          <div class="order-item-image">
            ${item.image
              ? `<img src="${item.image}" alt="${item.name}" />`
              : `<div class="order-item-placeholder">📦</div>`
            }
            <span class="order-item-qty">${item.quantity}</span>
          </div>
          <div class="order-item-info">
            <p class="order-item-name">${item.name}</p>
            ${item.size  ? `<p class="order-item-variant">Talla: ${item.size}</p>`  : ''}
            ${item.color ? `<p class="order-item-variant">Color: ${item.color}</p>` : ''}
          </div>
          <p class="order-item-price">$${Number(item.price * item.quantity).toLocaleString('es-CO')}</p>
        </div>
      `).join('')
    }

    const formatted = '$' + Number(subtotal).toLocaleString('es-CO')
    document.getElementById('order-subtotal').textContent = formatted
    document.getElementById('order-total').textContent    = formatted
  }

  // Confirmar pedido
  document.getElementById('place-order-btn')?.addEventListener('click', async () => {
    const user = localStorage.getItem('user')
    if (!user) {
      window.location.href = '/auth/login'
      return
    }

    const fullNameInput   = document.getElementById('full-name') as HTMLInputElement | null
    const streetInput     = document.getElementById('street') as HTMLInputElement | null
    const cityInput       = document.getElementById('city') as HTMLInputElement | null
    const departmentInput = document.getElementById('department') as HTMLInputElement | null

    const errorEl = document.getElementById('checkout-error') as HTMLElement | null
    const btn     = document.getElementById('place-order-btn') as HTMLButtonElement | null

    const fullName   = fullNameInput?.value.trim() || ''
    const street     = streetInput?.value.trim() || ''
    const city       = cityInput?.value.trim() || ''
    const department = departmentInput?.value.trim() || ''

    if (!fullName || !street || !city || !department) {
      if (errorEl) {
        errorEl.textContent   = 'Por favor completa todos los campos'
        errorEl.style.display = 'block'
      }
      return
    }

    const paymentMethod = (document.querySelector('input[name="payment"]:checked') as HTMLInputElement | null)?.value || 'wompi'

    if (!btn) {
      return
    }
    btn.disabled    = true
    btn.textContent = 'Procesando...'
    errorEl.style.display = 'none'

    try {
      const couponCode = getCouponCode() || undefined

      const orderItems = cartItems.get().map(item => ({
        productId: item.id,
        quantity:  item.quantity,
        size:      item.size,
        color:     item.color,
      }))

      const order = await api.orders.create({
        items: orderItems,
        couponCode,
        notes: `Envío a: ${street}, ${city}, ${department}`,
      })

      let paymentUrl = null

      if (paymentMethod === 'wompi') {
        const wompiResponse = await api.payments.wompi.createCheckout(order.id)
        paymentUrl = wompiResponse.paymentLink
      } else if (paymentMethod === 'mercadopago') {
        const mpResponse = await api.payments.createPreference({
          orderId: order.id,
          items: orderItems,
          payer: { email: JSON.parse(user).email, name: fullName },
        })
        paymentUrl = mpResponse.sandboxInitPoint || mpResponse.initPoint
      }

      clearCart()
      removeCoupon()

      if (paymentUrl) {
        window.location.href = paymentUrl
      } else {
        window.location.href = `/perfil/ordenes?success=true&orderId=${order.id}`
      }

    } catch (err) {
      if (errorEl) {
        errorEl.textContent   = err.message || 'Error al procesar el pedido'
        errorEl.style.display = 'block'
      }
      if (btn) {
        btn.disabled    = false
        btn.textContent = 'Confirmar pedido'
      }
    }
  })
</script>

<style>
  .checkout-page {
    padding-top:    calc(var(--header-height) + var(--space-8));
    padding-bottom: var(--space-16);
  }

  .page-title {
    font-family:   var(--font-serif);
    font-size:     2rem;
    font-weight:   600;
    color:         var(--color-black);
    margin-bottom: var(--space-8);
  }

  .checkout-empty {
    flex-direction:  column;
    align-items:     center;
    justify-content: center;
    gap:             var(--space-6);
    padding:         var(--space-16);
    text-align:      center;
    color:           var(--color-gray-400);
  }

  .checkout-layout {
    display:               grid;
    grid-template-columns: 1fr 380px;
    gap:                   var(--space-8);
    align-items:           start;
  }

  .form-section {
    margin-bottom:  var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom:  1.5px solid var(--color-gray-200);
  }

  .form-section:last-of-type { border-bottom: none; }

  .section-title {
    font-size:     1rem;
    font-weight:   600;
    color:         var(--color-black);
    margin-bottom: var(--space-4);
  }

  .form-grid {
    display:               grid;
    grid-template-columns: 1fr 1fr;
    gap:                   var(--space-4);
  }

  /* Métodos de pago */
  .payment-methods {
    display:        flex;
    flex-direction: column;
    gap:            var(--space-3);
  }

  .payment-option {
    cursor: pointer;
  }

  .payment-option input { display: none; }

  .payment-card {
    display:       flex;
    align-items:   center;
    gap:           var(--space-4);
    padding:       var(--space-4);
    border:        1.5px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    transition:    all var(--transition);
  }

  .payment-option input:checked + .payment-card {
    border-color: var(--color-black);
    background:   var(--color-gray-50);
  }

  .payment-icon  { font-size: 1.5rem; }

  .payment-name  { font-size: 0.9rem; font-weight: 500; color: var(--color-black); }
  .payment-desc  { font-size: 0.8rem; color: var(--color-gray-400); }

  .checkout-error {
    background:    #fee2e2;
    color:         #991b1b;
    padding:       var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size:     0.875rem;
    margin-bottom: var(--space-4);
  }

  .btn-full { width: 100%; }

  /* Resumen */
  .order-summary {
    background:    var(--color-white);
    border:        1.5px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding:       var(--space-6);
    position:      sticky;
    top:           calc(var(--header-height) + var(--space-4));
  }

  .summary-title {
    font-size:     1rem;
    font-weight:   600;
    color:         var(--color-black);
    margin-bottom: var(--space-4);
  }

  .order-item {
    display:       flex;
    align-items:   center;
    gap:           var(--space-3);
    padding:       var(--space-3) 0;
  }

  .order-item-image {
    position:      relative;
    width:         56px;
    height:        70px;
    border-radius: var(--radius-md);
    overflow:      hidden;
    background:    var(--color-gray-100);
    flex-shrink:   0;
  }

  .order-item-image img {
    width:      100%;
    height:     100%;
    object-fit: cover;
  }

  .order-item-placeholder {
    width:           100%;
    height:          100%;
    display:         flex;
    align-items:     center;
    justify-content: center;
    font-size:       1.5rem;
  }

  .order-item-qty {
    position:        absolute;
    top:             -6px;
    right:           -6px;
    background:      var(--color-black);
    color:           white;
    font-size:       0.65rem;
    font-weight:     600;
    width:           18px;
    height:          18px;
    border-radius:   50%;
    display:         flex;
    align-items:     center;
    justify-content: center;
  }

  .order-item-info { flex: 1; }
  .order-item-name    { font-size: 0.875rem; font-weight: 500; color: var(--color-black); }
  .order-item-variant { font-size: 0.75rem; color: var(--color-gray-400); }
  .order-item-price   { font-size: 0.875rem; font-weight: 600; color: var(--color-black); }

  .summary-divider {
    height:     1.5px;
    background: var(--color-gray-200);
    margin:     var(--space-4) 0;
  }

  .summary-row {
    display:         flex;
    justify-content: space-between;
    font-size:       0.9rem;
    color:           var(--color-gray-600);
    margin-bottom:   var(--space-3);
  }

  .discount-amount { color: var(--color-success); }
  .shipping-free   { color: var(--color-success); font-weight: 500; }

  /* Cupón */
  .coupon-section { margin-bottom: var(--space-4); }
  .coupon-input-group { display: flex; gap: var(--space-2); }
  .coupon-input {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    border: 1.5px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    text-transform: uppercase;
  }
  .coupon-input:focus {
    outline: none;
    border-color: var(--color-black);
  }
  .coupon-btn {
    padding: var(--space-2) var(--space-4);
    background: var(--color-black);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
  }
  .coupon-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .coupon-message {
    font-size: 0.75rem;
    margin-top: var(--space-2);
  }
  .coupon-message.error { color: var(--color-error); }
  .coupon-message.success { color: var(--color-success); }
  .coupon-applied {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    background: var(--color-gray-50);
    border: 1px solid var(--color-success);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--color-success);
  }
  .remove-coupon-btn {
    background: none;
    border: none;
    color: var(--color-gray-400);
    cursor: pointer;
    font-size: 1rem;
    padding: 0 var(--space-1);
  }
  .remove-coupon-btn:hover { color: var(--color-error); }

  .total-row {
    font-size:  1rem;
    font-weight: 600;
    color:      var(--color-black);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 768px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .form-grid       { grid-template-columns: 1fr; }
  }
</style>