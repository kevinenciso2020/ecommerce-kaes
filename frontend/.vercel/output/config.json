{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/descuentos/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/estudio/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/ordenes/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/productos/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/carrito/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/failure/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/pending/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/success/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/wompi-callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/?$",
			"dest": "_render"
		},
		{
			"src": "^/perfil/ordenes/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/perfil/?$",
			"dest": "_render"
		},
		{
			"src": "^/productos/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/productos/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}